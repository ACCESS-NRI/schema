{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "variable/time.json",
  "title": "time",
  "description": "The time variable for the dataset.",
  "type": "object",
  "properties": {
    "axis": {
      "const": "T"
    },
    "bounds": {
      "const": "time_bnds"
    },
    "calendar": {
      "const": "proleptic_gregorian"
    },
    "long_name": {
      "const": "time"
    },
    "standard_name": {
      "const": "time"
    },
    "units": {
      "description": "Units for time should be given as \"days since X\" where X is a date or datetime formatted as yyyy-mm-dd (HH:MM).",
      "examples": [
        "days since 0001-01-01 00:00",
        "days since 1970-01-01",
        "days since -5000-12-25"
      ],
      "pattern": "^days since -?\\d{4}-(1[012]|0[1-9])-(3[01]|[12][0-9]|0[1-9])( ([01][0-9]|2[0-3]):[0-5][0-9])?$"
    }
  },
  "additionalProperties": false
}
